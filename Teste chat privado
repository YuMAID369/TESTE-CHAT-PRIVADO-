    accept.Size = UDim2.new(0.4, 0, 0, 30)
    accept.Position = UDim2.new(0.05, 0, 0.65, 0)
    accept.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    accept.Text = "ACEITAR"
    accept.TextColor3 = Color3.fromRGB(0, 255, 0)
    accept.Parent = Notif

    local decline = accept:Clone()
    decline.Position = UDim2.new(0.55, 0, 0.65, 0)
    decline.Text = "RECUSAR"
    decline.TextColor3 = Color3.fromRGB(255, 0, 0)
    decline.Parent = Notif

    accept.MouseButton1Click:Connect(function()
        privatePartner = senderName
        Notif:Destroy()
        -- Notificar o outro que aceitou
        socket:Send(HttpService:JSONEncode({
            type = "private_response",
            accepted = true,
            target = senderName,
            sender = Player.Name
        }))
        -- Muda para aba privada
        G2L.TabPrivado.Indicator.Visible = true
        G2L.TabGlobal.Indicator.Visible = false
        G2L.GlobalContainer.Visible = false
        G2L.PrivateContainer.Visible = true
        currentTab = "Privado"
    end)

    decline.MouseButton1Click:Connect(function()
        Notif:Destroy()
        socket:Send(HttpService:JSONEncode({
            type = "private_response",
            accepted = false,
            target = senderName,
            sender = Player.Name
        }))
    end)
end

-- LOGICA DE MENSAGENS
local function AdicionarMensagem(data)
    local container = G2L.GlobalContainer
    if data.type == "private" then
        if (data.sender == Player.Name and data.target == privatePartner) or 
           (data.sender == privatePartner and data.target == Player.Name) then
            container = G2L.PrivateContainer
        else
            return -- Mensagem privada de outros, ignora
        end
    end

    local msgFrame = Instance.new("TextButton")
    msgFrame.Size = UDim2.new(1, 0, 0, 20)
    msgFrame.BackgroundTransparency = 1
    msgFrame.Text = ""
    msgFrame.Parent = container

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.RichText = true
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local color = (data.sender == Player.Name) and "rgb(255,255,255)" or "rgb(200,200,200)"
    label.Text = string.format("<font color='%s'>[%s]:</font> <font color='rgb(255,255,255)'>%s</font>", color, data.nickname or data.sender, data.message)
    label.Parent = msgFrame

    -- Double Click no Nickname para convite privado
    msgFrame.MouseButton1Click:Connect(function()
        local now = tick()
        if now - lastClickTime < 0.5 then
            if data.sender ~= Player.Name then
                print("Enviando pedido de chat privado para: " .. data.sender)
                socket:Send(HttpService:JSONEncode({
                    type = "private_request",
                    target = data.sender,
                    sender = Player.Name
                }))
            end
        end
        lastClickTime = now
    end)

    container.CanvasPosition = Vector2.new(0, 99999)
end

-- CONEXÃO WEBSOCKET
local socket
local function ConnectWebSocket()
    local success, res = pcall(function() return WebSocket.connect(wsUrl) end)
    if success and res then
        socket = res
        socket.OnMessage:Connect(function(msg)
            local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
            if ok then
                if data.type == "private_request" and data.target == Player.Name then
                    CriarNotificacao(data.sender)
                elseif data.type == "private_response" and data.target == Player.Name then
                    if data.accepted then
                        privatePartner = data.sender
                        print("Chat privado iniciado com " .. data.sender)
                    end
                elseif data.message then
                    AdicionarMensagem(data)
                end
            end
        end)
    else
        task.wait(5)
        ConnectWebSocket()
    end
end

-- ENVIO DE MENSAGENS
local function Enviar()
    if socket and G2L.Input.Text ~= "" then
        local payload = {
            sender = Player.Name,
            nickname = Player.DisplayName,
            message = G2L.Input.Text,
            type = (currentTab == "Privado" and privatePartner) and "private" or "global",
            target = privatePartner
        }
        socket:Send(HttpService:JSONEncode(payload))
        G2L.Input.Text = ""
    end
end

G2L.SendBtn.MouseButton1Click:Connect(Enviar)
G2L.Input.FocusLost:Connect(function(enter) if enter then Enviar() end end)

